# PostgreSQL (PostGIS)
POSTGRES_USER=manamap
POSTGRES_PASSWORD=manamap
POSTGRES_DB=manamap
DATABASE_URL=postgresql://manamap:manamap@localhost:5432/manamap

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=3000
API_HOST=localhost

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string-before-deploying-anywhere

# Apple Sign In — set to your app's Bundle ID (native) or Service ID (web)
APPLE_CLIENT_ID=com.manamap.app

# Discord OAuth2 — create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/v1/auth/discord/callback
