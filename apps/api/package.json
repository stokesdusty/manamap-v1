{
  "name": "@manamap/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed:stores": "ts-node --transpile-only -r tsconfig-paths/register prisma/seed-stores.ts",
    "db:seed:wpn": "ts-node --transpile-only -r tsconfig-paths/register prisma/seed-wpn.ts"
  },
  "prisma": {
    "seed": "ts-node --transpile-only -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@manamap/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.55.0",
    "axios": "^1.7.9",
    "bullmq": "^5.77.6",
    "expo-server-sdk": "^6.1.0",
    "fastify": "^4.29.1",
    "ioredis": "^5.11.0",
    "jose": "^4.15.9",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
