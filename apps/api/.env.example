DATABASE_URL=postgresql://manamap:manamap@localhost:5432/manamap
REDIS_URL=redis://localhost:6379
API_PORT=3000
API_HOST=localhost

# Auth — JWT (min 32 chars)
JWT_SECRET=<secret>

# Auth — Discord OAuth2 (optional; endpoints 503 when absent)
DISCORD_CLIENT_ID=<id>
DISCORD_CLIENT_SECRET=<secret>
DISCORD_REDIRECT_URI=manamap://auth/discord

# Auth — Apple Sign In (optional; endpoints 503 when absent)
APPLE_CLIENT_ID=<id>

# Auth — Google OAuth2 (optional; endpoints 503 when absent)
GOOGLE_CLIENT_ID=<id>
GOOGLE_CLIENT_SECRET=<secret>

# Comma-separated emails auto-promoted to ADMIN on login
ADMIN_EMAILS=

# Logging
LOG_LEVEL=info

# Error tracking — omit to disable Sentry entirely (true no-op)
SENTRY_DSN=

# Product analytics — omit POSTHOG_API_KEY to disable (true no-op)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# optional — enables /v1/dev/* dev-harness routes (non-production only)
DEV_TOOLS=true

# optional — disables rate limiting (CI/e2e)
THROTTLE_DISABLED=true
