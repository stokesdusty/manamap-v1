generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ProfileVisibility {
  PUBLIC
  CONNECTIONS_ONLY
  PRIVATE
}

enum LocationSharing {
  EVERYONE
  CONNECTIONS_ONLY
  NOBODY
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum EncounterResult {
  WIN
  LOSS
  DRAW
}

enum DeckSite {
  MOXFIELD
  ARCHIDEKT
}

enum EventSource {
  STORE
  DISCORD
  WIZARDS
}

enum EncounterSource {
  PRESENCE
  CONNECTION
  GAME
}

enum UserRole {
  USER
  PARTNER
  ADMIN
}

enum OfferType {
  FIRST_VISIT
  STREAK
}

enum ReportReason {
  HARASSMENT
  SPAM
  FAKE_PROFILE
  INAPPROPRIATE
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
}

enum ModerationStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum ModerationActionType {
  DISMISS
  WARN
  SUSPEND
  BAN
}

enum GameStatus {
  PENDING
  CONFIRMED
  DISPUTED
}

enum BroadcastAudience {
  CHECKED_IN_NOW
  TODAY
  EVENT_RSVPS
  RECENT_30D
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  bio          String?
  pronouns     String?
  avatarColors String[] @default([]) @map("avatar_colors")
  commander    String?
  powerLevel   Int?     @map("power_level")
  vibe         String?
  formats      String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  onboardedAt  DateTime? @map("onboarded_at")

  homeStoreId         String?  @map("home_store_id")
  role                UserRole @default(USER)
  moderationStatus    ModerationStatus @default(ACTIVE) @map("moderation_status")
  suspendedUntil      DateTime? @map("suspended_until")
  isBot               Boolean  @default(false) @map("is_bot")

  identities          Identity[]
  privacySettings     PrivacySettings?
  deckLinks           DeckLink[]
  sentConnections     Connection[]  @relation("Requester")
  receivedConnections Connection[]  @relation("Addressee")
  encounters          Encounter[]   @relation("UserEncounters")
  opponentEncounters  Encounter[]   @relation("OpponentEncounters")
  checkins            Checkin[]
  userBadges          UserBadge[]
  streaks             Streak[]
  refreshTokens       RefreshToken[]
  pushTokens          PushToken[]
  eventAttendees      EventAttendee[]
  homeStore           Store?          @relation("HomeStore", fields: [homeStoreId], references: [id])
  ownerships          StoreOwnership[]
  blocksMade          Block[]  @relation("Blocker")
  blocksAgainst       Block[]  @relation("Blocked")
  reportsMade         Report[] @relation("ReportsMade")
  reportsAgainst      Report[] @relation("ReportsAgainst")
  resolvedReports     Report[] @relation("ResolvedReports")
  targetedActions     ModerationAction[] @relation("TargetedActions")
  adminActions        ModerationAction[] @relation("AdminActions")
  gamesCreated        GameLog[]          @relation("GamesCreated")
  gamesWon            GameLog[]          @relation("GamesWon")
  gamePlayers         GamePlayer[]
  broadcastsSent      Broadcast[]        @relation("BroadcastsSent")

  @@map("users")
}

model Identity {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  provider      String
  providerId    String   @map("provider_id")
  discordHandle String?  @map("discord_handle")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("identities")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PrivacySettings {
  id                String            @id @default(uuid())
  userId            String            @unique @map("user_id")
  profileVisibility ProfileVisibility @default(PUBLIC) @map("profile_visibility")
  locationSharing   LocationSharing   @default(CONNECTIONS_ONLY) @map("location_sharing")
  discoverable      Boolean           @default(true)
  showDiscord       Boolean           @default(true) @map("show_discord")
  showDecks         Boolean           @default(true) @map("show_decks")
  showMetHistory    Boolean           @default(true) @map("show_met_history")
  storeMessages     Boolean           @default(true) @map("store_messages")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("privacy_settings")
}

model Format {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  encounters Encounter[]
  events     Event[]

  @@map("formats")
}

model DeckLink {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  site      DeckSite
  name      String
  url       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deck_links")
}

model Connection {
  id          String           @id @default(uuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  status      ConnectionStatus @default(PENDING)
  via         String?
  note        String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@map("connections")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

model Store {
  id         String   @id @default(uuid())
  name       String
  address    String?
  city       String?
  state      String?
  zip        String?
  timezone   String?
  website    String?
  discordUrl String?  @map("discord_url")
  isPartner  Boolean  @default(false) @map("is_partner")
  // geom is a PostGIS geography(Point,4326) — managed via $queryRaw / $executeRaw
  geom                 Unsupported("geography(Point,4326)")?
  checkinRadiusMeters  Int?     @map("checkin_radius_meters")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  checkins     Checkin[]
  events       Event[]
  encounters   Encounter[]
  rewardOffers RewardOffer[]
  streaks      Streak[]
  userBadges   UserBadge[]
  homeUsers    User[]          @relation("HomeStore")
  ownerships   StoreOwnership[]
  gameLogs     GameLog[]
  broadcasts   Broadcast[]

  @@unique([name, city])
  @@map("stores")
}

model Checkin {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  storeId      String    @map("store_id")
  eventId      String?   @map("event_id")
  checkedInAt  DateTime  @default(now()) @map("checked_in_at")
  checkedOutAt DateTime? @map("checked_out_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store  @relation(fields: [storeId], references: [id])
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@map("checkins")
}

model Event {
  id              String      @id @default(uuid())
  storeId         String      @map("store_id")
  formatId        String?     @map("format_id")
  source          EventSource @default(STORE)
  name            String
  description     String?
  url             String?
  externalId      String?     @map("external_id")
  eventChannelUrl String?     @map("event_channel_url")
  startsAt        DateTime    @map("starts_at")
  endsAt          DateTime?   @map("ends_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  store      Store           @relation(fields: [storeId], references: [id])
  format     Format?         @relation(fields: [formatId], references: [id])
  attendees  EventAttendee[]
  encounters Encounter[]
  checkins   Checkin[]

  @@map("events")
}

model EventAttendee {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  eventId String   @map("event_id")
  rsvpAt  DateTime @default(now()) @map("rsvp_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_attendees")
}

model Encounter {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  opponentId String          @map("opponent_id")
  storeId    String?         @map("store_id")
  eventId    String?         @map("event_id")
  formatId   String?         @map("format_id")
  source     EncounterSource @default(GAME)
  result     EncounterResult
  notes      String?
  gameId     String?         @map("game_id")
  createdAt  DateTime        @default(now()) @map("created_at")

  user     User     @relation("UserEncounters", fields: [userId], references: [id], onDelete: Cascade)
  opponent User     @relation("OpponentEncounters", fields: [opponentId], references: [id])
  store    Store?   @relation(fields: [storeId], references: [id])
  event    Event?   @relation(fields: [eventId], references: [id])
  format   Format?  @relation(fields: [formatId], references: [id])
  gameLog  GameLog? @relation(fields: [gameId], references: [id], onDelete: SetNull)

  @@map("encounters")
}

model Badge {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String   @unique
  description String?
  icon        String   @default("🏅")
  criteria    Json
  createdAt   DateTime @default(now()) @map("created_at")

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  badgeId  String   @map("badge_id")
  storeId  String?  @map("store_id")
  earnedAt DateTime @default(now()) @map("earned_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge  @relation(fields: [badgeId], references: [id])
  store Store? @relation(fields: [storeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Streak {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  storeId       String   @map("store_id")
  currentStreak Int      @default(1) @map("current_streak")
  longestStreak Int      @default(1) @map("longest_streak")
  totalCheckins Int      @default(1) @map("total_checkins")
  lastCheckinAt DateTime @map("last_checkin_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@map("streaks")
}

model StoreOwnership {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@map("store_ownerships")
}

model RewardOffer {
  id             String    @id @default(uuid())
  storeId        String    @map("store_id")
  type           OfferType @default(FIRST_VISIT)
  title          String
  description    String?
  terms          String?
  redemptionCode String    @unique @map("redemption_code")
  active         Boolean   @default(true)
  streakRequired Int?      @map("streak_required")
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("reward_offers")
}

model Block {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String       @map("reporter_id")
  reportedId     String       @map("reported_id")
  reason         ReportReason
  detail         String?
  context        String?
  status         ReportStatus @default(OPEN)
  resolvedById   String?      @map("resolved_by_id")
  resolvedAt     DateTime?    @map("resolved_at")
  resolutionNote String?      @map("resolution_note")
  createdAt      DateTime     @default(now()) @map("created_at")

  reporter   User @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported   User @relation("ReportsAgainst", fields: [reportedId], references: [id])
  resolvedBy User? @relation("ResolvedReports", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@map("reports")
}

model GameLog {
  id          String     @id @default(uuid())
  createdById String     @map("created_by_id")
  storeId     String?    @map("store_id")
  format      String?
  winnerId    String     @map("winner_id")
  status      GameStatus @default(PENDING)
  note        String?
  createdAt   DateTime   @default(now()) @map("created_at")
  confirmedAt DateTime?  @map("confirmed_at")

  createdBy  User        @relation("GamesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  winner     User        @relation("GamesWon", fields: [winnerId], references: [id], onDelete: Cascade)
  store      Store?      @relation(fields: [storeId], references: [id], onDelete: SetNull)
  players    GamePlayer[]
  encounters Encounter[]

  @@map("game_logs")
}

model GamePlayer {
  id        String  @id @default(uuid())
  gameLogId String  @map("game_log_id")
  userId    String  @map("user_id")
  deck      String?
  confirmed Boolean @default(false)

  gameLog GameLog @relation(fields: [gameLogId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameLogId, userId])
  @@map("game_players")
}

model ModerationAction {
  id           String               @id @default(uuid())
  reportId     String?              @map("report_id")
  targetUserId String               @map("target_user_id")
  adminId      String               @map("admin_id")
  action       ModerationActionType
  note         String?
  createdAt    DateTime             @default(now()) @map("created_at")

  targetUser User @relation("TargetedActions", fields: [targetUserId], references: [id], onDelete: Cascade)
  admin      User @relation("AdminActions", fields: [adminId], references: [id], onDelete: Cascade)

  @@map("moderation_actions")
}

model Broadcast {
  id             String            @id @default(uuid())
  storeId        String            @map("store_id")
  sentById       String            @map("sent_by_id")
  audience       BroadcastAudience
  title          String
  body           String
  eventId        String?           @map("event_id")
  recipientCount Int               @default(0) @map("recipient_count")
  createdAt      DateTime          @default(now()) @map("created_at")

  store  Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sentBy User  @relation("BroadcastsSent", fields: [sentById], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@map("broadcasts")
}
